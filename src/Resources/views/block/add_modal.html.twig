{% embed '@AmzsCore/Components/Modal/base.html.twig' with {
    title: title|default('Add Block'),
    modalDialogCss: 'mw-650px',
    modalBodyCss: 'modal-body mx-3 mx-xl-12 pt-0 pb-5'
} %}

    {% block body %}
            {{ form_start(form) }}
            <div class="fv-row mb-7">
                <!--begin::Label-->
                <label class="required fs-6 fw-semibold mb-2">Title</label>
                <!--end::Label-->
                <!--begin::Input-->
                {{ form_widget(form.title, {attr: {'class': "form-control fs-7"}}) }}
                <!--end::Input-->
            </div>
            <div class="fv-row mb-7">
                <!--begin::Label-->
                <label class="required fs-6 fw-semibold mb-2">Type</label>
                <!--end::Label-->
                <!--begin::Input-->
                {{ form_widget(form.type) }}
                <!--end::Input-->
            </div>
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}